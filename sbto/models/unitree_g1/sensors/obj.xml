<mujoco>
    <sensor>
        <!-- obj - floor  -->
        <contact geom1="obj" body2="static" reduce="maxforce" data="found force" num="1" name="obj_static_cnt"/>
        <!-- obj position and orientation  -->
        <framepos objtype="geom" objname="obj" name="global_pos_obj"/>
        <framequat objtype="geom" objname="obj" name="global_quat_obj"/>
        <!-- hands contact -->
        <contact geom1="obj" subtree2="left_wrist_pitch_link" reduce="maxforce" data="found force" num="1" name="left_hand_cnt"/>
        <contact geom1="obj" subtree2="right_wrist_pitch_link" reduce="maxforce" data="found force" num="1" name="right_hand_cnt"/>
    </sensor>
</mujoco>