        <actuatorfrc name="waist_yaw_joint" actuator="waist_yaw_joint"/>
        <actuatorfrc name="left_shoulder_pitch_joint" actuator="left_shoulder_pitch_joint"/>
        <actuatorfrc name="left_shoulder_roll_joint" actuator="left_shoulder_roll_joint"/>
        <actuatorfrc name="left_shoulder_yaw_joint" actuator="left_shoulder_yaw_joint"/>
        <actuatorfrc name="left_elbow_joint" actuator="left_elbow_joint"/>
        <actuatorfrc name="left_wrist_roll_joint" actuator="left_wrist_roll_joint"/>
        <actuatorfrc name="right_shoulder_pitch_joint" actuator="right_shoulder_pitch_joint"/>
        <actuatorfrc name="right_shoulder_roll_joint" actuator="right_shoulder_roll_joint"/>
        <actuatorfrc name="right_shoulder_yaw_joint" actuator="right_shoulder_yaw_joint"/>
