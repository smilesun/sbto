        <actuatorfrc name="left_ankle_roll_joint" actuator="left_ankle_roll_joint"/>
        <actuatorfrc name="right_hip_pitch_joint" actuator="right_hip_pitch_joint"/>
        <actuatorfrc name="right_hip_roll_joint" actuator="right_hip_roll_joint"/>
        <actuatorfrc name="right_hip_yaw_joint" actuator="right_hip_yaw_joint"/>
        <actuatorfrc name="right_knee_joint" actuator="right_knee_joint"/>
        <actuatorfrc name="right_ankle_pitch_joint" actuator="right_ankle_pitch_joint"/>
